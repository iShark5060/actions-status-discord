{
  "name": "actions-status-discord",
  "version": "1.0.1",
  "private": true,
  "description": "Post Github Actions CI status to Discord",
  "license": "MIT",
  "author": "Sarisia",
  "type": "module",
  "main": "lib/index.mjs",
  "scripts": {
    "validate": "node run-quality-checks.mjs",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write .",
    "check-format": "oxfmt --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "build": "esbuild src/main.ts --bundle --platform=node --format=esm --target=node24 --outfile=lib/index.mjs --minify",
    "deps": "pnpm dlx npm-check-updates --target newest -u"
  },
  "dependencies": {
    "@actions/core": "^3.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "esbuild": "^0.28.1",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.10.0"
}
